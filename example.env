# .env - loaded in all environments
# .env.production - loaded only in production environments
# .env.development - loaded only in development environments

VITE_REMOVE_GENERATED_CITE=FALSE
VITE_API_PATH=http://127.0.0.1:8000

# Force Ask mode (hides write mode dropdown and always uses /ask endpoint)
# Default: true
VITE_FORCE_ASK=true

# Force Private Search tool to be enabled automatically
# Default: true
VITE_FORCE_PRIVATE_SEARCH=true

# Chat home default input templates
# Supports {username}; values are injected at build time.
# VITE_CHAT_HOME_DEFAULT_INPUT_ZH=
# VITE_CHAT_HOME_DEFAULT_INPUT_EN=
